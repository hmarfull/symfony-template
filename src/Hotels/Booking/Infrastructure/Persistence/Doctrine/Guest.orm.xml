<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                          https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <embeddable name="App\Hotels\Booking\Domain\Guest">
        <field name="name" type="string" column="name"/>
        <field name="lastname" type="string" column="lastname"/>
        <field name="birthdate" type="datetime_immutable_microseconds" column="birthdate"/>
        <field name="passport" type="string" column="passport"/>
        <field name="country" type="string" column="country"/>
    </embeddable>

</doctrine-mapping>